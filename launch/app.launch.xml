<launch>
<!--  
namespace is applied first, before remapping. 
If you want to remap topic namespace : you need to remove the / in the topic_name in the <remap…> 
-->
    <node pkg="ros2_tmplt_py" exec="publisher"/>
    <node pkg="ros2_tmplt_cpp" exec="subscriber"/>

    <node pkg="ros2_tmplt_py" exec="publisher" name="publisher2" namespace="group2">
        <remap from="counter" to="counter2"/>
    </node>
    <node pkg="ros2_tmplt_cpp" exec="subscriber"  namespace="group2">
        <remap from="counter" to="counter2"/>
    </node>

    <node pkg="ros2_tmplt_cpp" exec="parameter"  namespace="group3">
        <param name="name" value="C6PO"/>
        <!-- Load params/configuration from file -->
        <!-- <param from=”$(find-pkg-share <pkg_name>)/config/<yaml_file> />” -->

    </node>



    <!-- Insert an other launch file from the same folder : can be python launch file -->
    <!-- <include file=”$(find-pkg-share ros2_tmplt_launch_bringup)/launch/app.launch.py” /> -->
</launch>

<!--
<remap …> : équivalent to option \-\-ros-args -r
<param …> : equivalent to option \-\-ros-args -p
-->
